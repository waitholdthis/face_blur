# Copy to .env and adjust. Used by docker-compose.

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=anonymization_vault

# --- Public URL the browser uses to reach the API (for signed asset URLs) ---
PUBLIC_BASE_URL=http://localhost:8000

# --- Auth ---
# CHANGE THESE for any real deployment.
JWT_SECRET=change-me-in-production-please-32chars-min
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- CORS: comma-separated origins allowed to call the API ---
CORS_ORIGINS=http://localhost:3000

# --- Vision calibration / redaction ---
# Conservative starter values; validate against authorized local imagery.
SFACE_MATCH_THRESHOLD=0.45
MATCH_MIN_MARGIN=0.08
REDACTION_PADDING_RATIO=0.25
REDACTION_MODE=hybrid
MAX_REFERENCE_IMAGES=5
MAX_UPLOAD_BYTES=20971520

# --- Registry mirrors (optional) ---
# If Docker Hub is unreachable in your environment, point these at a mirror:
# POSTGRES_IMAGE=mirror.gcr.io/pgvector/pgvector:pg16
# REDIS_IMAGE=mirror.gcr.io/library/redis:7-alpine
# PYTHON_IMAGE=mirror.gcr.io/library/python:3.11-slim
# NODE_IMAGE=mirror.gcr.io/library/node:22-alpine
