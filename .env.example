# Copy to .env and adjust. Used by docker-compose.
#
# ── GO-LIVE CHECKLIST ─────────────────────────────────────────────────────────
# Before serving real traffic, set ALL of the following (the API refuses to
# start in production mode with insecure values):
#   1. ENVIRONMENT=production
#   2. JWT_SECRET        → unique random value, 32+ chars:  openssl rand -hex 32
#   3. ADMIN_PASSWORD    → strong unique password, 12+ chars
#   4. POSTGRES_PASSWORD → strong unique password
#   5. PUBLIC_BASE_URL   → the HTTPS URL your API is reachable at
#   6. CORS_ORIGINS      → your real frontend origin(s), never "*"
#   7. NEXT_PUBLIC_SHOW_DEMO_LOGIN=0 (default) so no demo credentials render
# Terminate TLS in front of both ports (Caddy/nginx/traefik or your platform's
# load balancer) and back up the postgres-data + media-storage volumes.
# ──────────────────────────────────────────────────────────────────────────────

# development (permissive defaults) or production (secure secrets enforced).
ENVIRONMENT=development

# Where the web (3000) and API (8000) ports bind. Keep the default for local
# use; set 127.0.0.1 on a public server so traffic only enters through the
# TLS reverse proxy (see deploy/Caddyfile).
# BIND_IP=127.0.0.1

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=anonymization_vault

# --- Public URL the browser uses to reach the API (for signed asset URLs) ---
PUBLIC_BASE_URL=http://localhost:8000

# --- Auth ---
# CHANGE THESE for any real deployment (enforced when ENVIRONMENT=production).
JWT_SECRET=change-me-in-production-please-32chars-min
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- CORS: comma-separated origins allowed to call the API ---
CORS_ORIGINS=http://localhost:3000

# --- Login page demo-credential hint (1 = show; keep 0 in production) ---
NEXT_PUBLIC_SHOW_DEMO_LOGIN=0

# --- Vision calibration / redaction ---
# Conservative starter values; validate against authorized local imagery.
YUNET_SCORE_THRESHOLD=0.60
YUNET_REFINE_SCORE_THRESHOLD=0.40
DETECTOR_REFINEMENT_ENABLED=true
SFACE_MATCH_THRESHOLD=0.45
MATCH_MIN_MARGIN=0.08
REDACTION_PADDING_RATIO=0.25
REDACTION_MODE=hybrid
MAX_REFERENCE_IMAGES=5
MAX_UPLOAD_BYTES=20971520
MAX_BATCH_UPLOAD_FILES=25
MAX_BATCH_UPLOAD_BYTES=104857600

# --- Registry mirrors (optional) ---
# If Docker Hub is unreachable in your environment, point these at a mirror:
# POSTGRES_IMAGE=mirror.gcr.io/pgvector/pgvector:pg16
# REDIS_IMAGE=mirror.gcr.io/library/redis:7-alpine
# PYTHON_IMAGE=mirror.gcr.io/library/python:3.11-slim
# NODE_IMAGE=mirror.gcr.io/library/node:22-alpine
